---
import "../styles/global.css"

import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

import NewspaperLayout from "../layouts/NewspaperLayout.astro";
import ArticleFilter from "../components/ArticleFilter";

const articles: CollectionEntry<"articles">[] = await getCollection("articles");

---

<NewspaperLayout title="El diario deportivo">
	
 <ArticleFilter articles={articles} client:load />

</NewspaperLayout> 
